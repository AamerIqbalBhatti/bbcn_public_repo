\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces \textbf  {The bistable switch (136-node model).} (A) The two attractors and the survival$\to $apoptosis flip under sustained genotoxic stress. (B) Three-cohort routing (robust $z$-score): about half apoptotic, a quarter survival, the rest mixed, consistent across platforms. (C) Biological check: survival-routed patients are 89--95\% uncoupled, versus 26--37\% cohort-wide.}}{16}{figure.caption.17}\protected@file@percent }
\newlabel{fig:switch}{{5}{16}{\textbf {The bistable switch (136-node model).} (A) The two attractors and the survival$\to $apoptosis flip under sustained genotoxic stress. (B) Three-cohort routing (robust $z$-score): about half apoptotic, a quarter survival, the rest mixed, consistent across platforms. (C) Biological check: survival-routed patients are 89--95\% uncoupled, versus 26--37\% cohort-wide}{figure.caption.17}{}}
